# Variables de entorno — ajustar y NO commitear con secretos reales

# Puertos locales (distintos al VPS para evitar conflictos)
POSTGRES_PORT=5433
REDIS_PORT=6380
API_PORT=8080

# PostgreSQL
POSTGRES_DB=incident_manager
POSTGRES_USER=im_user
POSTGRES_PASSWORD=changeme_dev

# Redis (vacío = sin contraseña en local)
REDIS_PASSWORD=

# JWT — cambiar en producción (mínimo 64 chars)
JWT_SECRET_KEY=CAMBIAR_POR_SECRETO_LARGO_Y_SEGURO_64_CHARS_MINIMO
JWT_ISSUER=incident-manager
JWT_AUDIENCE=incident-manager-clients

# Webhooks HMAC
PROMETHEUS_WEBHOOK_SECRET=prometheus_secret_dev
GITEA_WEBHOOK_SECRET=gitea_secret_dev

# Traefik (solo producción)
TRAEFIK_NETWORK=traefik_proxy
DOMAIN_API=api.tudominio.com

REGISTRY_URL=gitea.tudominio.com
REGISTRY_USER=tuusuario
